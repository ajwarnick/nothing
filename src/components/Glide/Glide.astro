---

import '../../../node_modules/glider-js/glider.css';
---

<style lang="scss" is:global>

    .glider-contain{
        color: var(--nothing-background-color);

        .glider{
            background-color: rgb(133, 169, 157);
            div{
                margin: 10vh 0;
            }
        }
        .glider-prev, .glider-next{
            top: calc(50% - 40px);
            transition: unset;
            color:var(--nothing-ui-color);

            &:hover{
                
            }
            &:hover:not(.disabled){
                color: var(--nothing-background-color);
            }
        }

        .glider-prev{
            left: 0;
        }
        .glider-next{
            right: 0;
        }
        .glider-dots{
            margin: auto;
            z-index: 100;
            position: absolute;
            bottom: 5px;
            left: 0;
            right: 0;

            .glider-dot{
                width: 8px;
                height: 8px;
                color: var(--nothing-background-color);

                &.active{
                    background: var(--nothing-ui-color);
                }
            }
        }
    }
    
</style>

<div class="glider-contain">
  <div class="glider">
    <div>1 your content here</div>
    <div>2 your content here</div>
    <div>3 your content here</div>
    <div>4 your content here</div>
  </div>

  <button aria-label="Previous" class="glider-prev">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" width='1em' height='1em'><path fill="currentColor" d="m4 10l9 9l1.4-1.5L7 10l7.4-7.5L13 1z"/></svg>
  </button>
  <button aria-label="Next" class="glider-next">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" width='1em' height='1em'><path fill="currentColor" d="M7 1L5.6 2.5L13 10l-7.4 7.5L7 19l9-9z"/></svg>
  </button>
  <div role="tablist" class="glider-dots"></div>
</div>


<script>
    // @ts-ignore
    import Glider from 'glider-js';
    // console.log(Glider);
    const glideElements = document.querySelectorAll(".glider");
    
    glideElements.forEach((gld) => {
        console.log(gld);

        new Glider(gld, {
            slidesToShow: 1,
            dots: '.glider-dots',
            draggable: false,
            arrows: {
                prev: '.glider-prev',
                next: '.glider-next'
            }
        });
    });

//    new Glider(document.querySelector('.glider'), {
//         slidesToShow: 1,
//         dots: '#dots',
//         draggable: true,
//         arrows: {
//             prev: '.glider-prev',
//             next: '.glider-next'
//         }
//     });
</script>